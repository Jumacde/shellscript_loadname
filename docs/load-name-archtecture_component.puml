@startuml
package "Application_Layer" {
	component [main.sh] as main
	component [input_name] as input
	component [get_name] as get
	
	main .> get << run scripts >>
	get .> input << get inputted name >>

}

package "Log_Layer" {
	component [log_manager.sh] as log
	component [.env] as env
	component [.gitignore] as git
	
	file "test_loadname.log(Test: test_log)" as testlog
	file "prod_loadname.log(Prod: prod_log)" as prodlog

	main .> log: << import function:\nchoice and confirm log path >>
	log .> env: << load log path >>
	env .> testlog: << include >>
	env .> prodlog: << include >>
	env -down.> git: << hide log path \non the github and gitlab >>
}

main -down.> log: << switch and write >>\n(Development\n/Production)
input -down.> log: << switch and write >>\n(Development\n/Production)
get -down.> log: << switch and write >> \n(Development\n/Production)

@enduml
